# GitHub API — used by lib/github.ts to fetch repos for the projects page.
# Create a fine-grained Personal Access Token at https://github.com/settings/tokens
# (no scopes needed for public repos).
GITHUB_USERNAME=
GITHUB_API_KEY=
GITHUB_API_VER=2022-11-28

# Optional. Public site origin used by metadata, sitemap and OG image generation.
# Example: https://kibar.pro
NEXT_PUBLIC_SITE_URL=

# Optional. Plausible analytics. Set the domain to enable; leave empty to disable.
# Example: kibar.pro
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional. Override the script URL for self-hosted Plausible.
# Defaults to https://plausible.io/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=
